root = true

# Global defaults — all file types
[*]
end_of_line = lf
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Frontend files (already 2-space from global default — explicit for clarity)
[*.{ts,html,scss,css,json,yaml,yml}]
indent_size = 2

# C# and project files
[*.{cs,csproj,slnx,vb}]
indent_size = 4
tab_width = 4

# Markdown: preserve intentional trailing spaces (two spaces = line break)
[*.md]
trim_trailing_whitespace = false

# Makefiles require tabs — override global indent_style
[Makefile]
indent_style = tab

##############################################################################
# C# code style rules (Roslyn / .editorconfig analyzer integration)
##############################################################################

[*.cs]

# Using directives
dotnet_remove_unnecessary_imports = true
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_using_directive_placement = outside_namespace:error
csharp_prefer_simple_using_statement = true:error
dotnet_diagnostic.IDE0005.severity = error

# var usage
csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_elsewhere = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_properties = true:error
csharp_style_expression_bodied_constructors = false:error
csharp_style_expression_bodied_operators = false:error
csharp_style_expression_bodied_indexers = true:error
csharp_style_expression_bodied_accessors = true:error
csharp_style_expression_bodied_lambdas = true:error
csharp_style_expression_bodied_local_functions = false:error

# Braces
csharp_prefer_braces = true:error

# General style preferences
dotnet_style_prefer_auto_properties = true:error
dotnet_style_object_initializer = true:error
dotnet_style_collection_initializer = true:error
dotnet_style_prefer_simplified_boolean_expressions = true:error
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion
dotnet_style_prefer_conditional_expression_over_return = true:suggestion
dotnet_style_coalesce_expression = true:error
dotnet_style_null_propagation = true:error
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:error
dotnet_style_prefer_inferred_tuple_names = true:error
dotnet_style_explicit_tuple_names = true:error
dotnet_style_prefer_inferred_anonymous_type_member_names = true:error
dotnet_style_prefer_compound_assignment = true:error
dotnet_style_prefer_simplified_interpolation = true:error

# Modern C# features
csharp_style_namespace_declarations = file_scoped:error
csharp_style_prefer_top_level_statements = true:error
csharp_style_prefer_primary_constructors = true:error
csharp_prefer_system_threading_lock = true:error

# Modifiers
dotnet_style_require_accessibility_modifiers = always:error

# Naming: private readonly fields → _camelCase
dotnet_naming_rule.private_fields_should_be_camel_case.severity = error
dotnet_naming_rule.private_fields_should_be_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_should_be_camel_case.style = camel_case_underscore

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers = readonly

dotnet_naming_style.camel_case_underscore.capitalization = camel_case
dotnet_naming_style.camel_case_underscore.required_prefix = _

# Naming: private non-readonly fields → _camelCase
dotnet_naming_rule.private_nonreadonly_fields_should_be_camel_case.severity = error
dotnet_naming_rule.private_nonreadonly_fields_should_be_camel_case.symbols = private_nonreadonly_fields
dotnet_naming_rule.private_nonreadonly_fields_should_be_camel_case.style = camel_case_underscore

dotnet_naming_symbols.private_nonreadonly_fields.applicable_kinds = field
dotnet_naming_symbols.private_nonreadonly_fields.applicable_accessibilities = private

# Naming: parameters → camelCase
dotnet_naming_rule.parameters_should_be_camel_case.severity = error
dotnet_naming_rule.parameters_should_be_camel_case.symbols = method_parameters
dotnet_naming_rule.parameters_should_be_camel_case.style = simple_camel_case

dotnet_naming_symbols.method_parameters.applicable_kinds = parameter

dotnet_naming_style.simple_camel_case.capitalization = camel_case
dotnet_naming_style.simple_camel_case.required_prefix =
dotnet_naming_style.simple_camel_case.word_separator =
